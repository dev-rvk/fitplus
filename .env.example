# === Database ===
# Local: Docker Compose Postgres (see docker-compose.yml)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fitplus"

# Production: set this to your Supabase Postgres connection string in Vercel env vars
# DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"

# === Auth ===
# Used to sign JWT session cookies. Use a long random string (64+ chars).
AUTH_JWT_SECRET="replace-with-a-long-random-secret"
